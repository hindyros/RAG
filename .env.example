# ── Mistral AI ──────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_api_key_here
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=mistral-large-latest

# ── Storage ──────────────────────────────────────────────────────────────────
# Directory where embeddings and metadata are persisted to disk
STORE_PATH=./data/store

# ── Chunking ─────────────────────────────────────────────────────────────────
# Approximate token count per chunk (1 token ≈ 4 characters)
CHUNK_SIZE_TOKENS=512
# Overlap between adjacent chunks in tokens
CHUNK_OVERLAP_TOKENS=64

# ── Retrieval ────────────────────────────────────────────────────────────────
# How many candidates each retriever fetches (before RRF fusion)
TOP_K_RETRIEVAL=10
# How many chunks survive after reranking (fed to the LLM)
TOP_K_RERANK=5
# Reciprocal Rank Fusion constant (higher → less aggressive rank weighting)
RRF_K_CONSTANT=60

# ── Quality gates ────────────────────────────────────────────────────────────
# Minimum cosine similarity of the top result to avoid refusal
MIN_SIMILARITY_THRESHOLD=0.35
# Minimum confidence from intent detector to trust its sub-intent
INTENT_CONFIDENCE_MIN=0.60

# ── Batching ─────────────────────────────────────────────────────────────────
# Maximum chunks per Mistral embed API call
MAX_EMBED_BATCH_SIZE=32

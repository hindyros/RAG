# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose which provider to use: "openai" or "mistral"
# Set the corresponding API key below. The other key can be left blank.
# NOTE: switching providers requires deleting ./data/store and re-ingesting
#       all documents (embedding dimensions differ between providers).
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Mistral AI ────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=mistral-large-latest

# ── Storage ───────────────────────────────────────────────────────────────────
STORE_PATH=./data/store

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
RRF_K_CONSTANT=60

# ── Quality gates ─────────────────────────────────────────────────────────────
MIN_SIMILARITY_THRESHOLD=0.35
INTENT_CONFIDENCE_MIN=0.60

# ── Batching ──────────────────────────────────────────────────────────────────
MAX_EMBED_BATCH_SIZE=32
